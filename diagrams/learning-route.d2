  shape: hexagon
  style.fill: "#fce7f3"; style.stroke: "#ec4899"; style.stroke-width: 3
  style.font-color: "#9d174d"; style.font-size: 22; style.bold: true
}
L3_S1 -> L3_S2: { style.stroke: "#f472b6"; style.stroke-width: 5 }
L3_S2: {
