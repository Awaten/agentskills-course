direction: down
scale: 2.2

title: {
  label: "▎AGENT SKILLS 學習路線圖"
  shape: page
  style.fill: "#0f172a"
  style.font-color: "#f1f5f9"
  style.font-size: 40
  style.bold: true
}

# ═══ L1 新手 ═══
title -> L1_label
L1_label: {
  label: "🚀 路徑一：新手快速入門（約 20 分鐘）"
  style.font-size: 30
  style.font-color: "#2563eb"
  style.bold: true
  shape: text
}
L1_label -> L1_S1
L1_S1: {
  label: "S1\nAgent Skills\n是什麼？"
  shape: hexagon
  style.fill: "#dbeafe"; style.stroke: "#3b82f6"; style.stroke-width: 3
  style.font-color: "#1e40af"; style.font-size: 24; style.bold: true
}
L1_S1 -> L1_S2: { style.stroke: "#60a5fa"; style.stroke-width: 5 }
L1_S2: {
  label: "S2\nSKILL.md\n格式速覽"
  shape: hexagon
  style.fill: "#dbeafe"; style.stroke: "#3b82f6"; style.stroke-width: 3
  style.font-color: "#1e40af"; style.font-size: 24; style.bold: true
}
L1_S2 -> L1_S3: { style.stroke: "#60a5fa"; style.stroke-width: 5 }
L1_S3: {
  label: "S3\nDescription\n觸發優化"
  shape: hexagon
  style.fill: "#dbeafe"; style.stroke: "#3b82f6"; style.stroke-width: 3
  style.font-color: "#1e40af"; style.font-size: 24; style.bold: true
}
L1_S3 -> L1_DONE: { style.stroke: "#22c55e"; style.stroke-width: 6 }
L1_DONE: {
  label: "✅ 掌握核心概念"
  shape: circle
  style.fill: "#22c55e"; style.font-color: "white"
  style.font-size: 22; style.bold: true
}

# ═══ L2 實戰 ═══
L1_DONE -> L2_label
L2_label: {
  label: "🔧 路徑二：實戰派上手指南（約 40 分鐘）"
  style.font-size: 30
  style.font-color: "#d97706"
  style.bold: true
  shape: text
}
L2_label -> L2_S1
L2_S1: {
  label: "S5\n從零到發布\n骰子 Skill"
  shape: hexagon
  style.fill: "#fef3c7"; style.stroke: "#f59e0b"; style.stroke-width: 3
  style.font-color: "#92400e"; style.font-size: 24; style.bold: true
}
L2_S1 -> L2_S2: { style.stroke: "#fbbf24"; style.stroke-width: 5 }
L2_S2: {
  label: "S4\n7 個高效\n套路心法"
  shape: hexagon
  style.fill: "#fef3c7"; style.stroke: "#f59e0b"; style.stroke-width: 3
  style.font-color: "#92400e"; style.font-size: 24; style.bold: true
}
L2_S2 -> L2_S3: { style.stroke: "#fbbf24"; style.stroke-width: 5 }
L2_S3: {
  label: "Ch4\n從零建置\n完整 Skill"
  shape: hexagon
  style.fill: "#fef3c7"; style.stroke: "#f59e0b"; style.stroke-width: 3
  style.font-color: "#92400e"; style.font-size: 24; style.bold: true
}
L2_S3 -> L2_DONE: { style.stroke: "#22c55e"; style.stroke-width: 6 }
L2_DONE: {
  label: "✅ 寫過完整 Skill"
  shape: circle
  style.fill: "#22c55e"; style.font-color: "white"
  style.font-size: 22; style.bold: true
}

# ═══ L3 專家 ═══
L2_DONE -> L3_label
L3_label: {
  label: "🎓 路徑三：專業系統學習（約 12 小時）"
